seed: 0
num_images: 100
batch_size: 1
bandwidth_mbps: 100.0

# Emulated speed settings.
# Use measured segment latency multiplied by these factors.
mobile_latency_scale: 4.0
server_latency_scale: 1.0

# Limit candidates to avoid brute-force explosion.
max_candidates_per_branch: 5

models:
  - name: vgg11
    structure: chain
    input_size: 224
  - name: alexnet
    structure: dag_weak
    input_size: 224
  - name: resnet18
    structure: residual_dag
    input_size: 224
  - name: inception_v3
    structure: multi_branch_dag
    input_size: 299

results_dir: results
